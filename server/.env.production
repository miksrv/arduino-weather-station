#--------------------------------------------------------------------
# Example Environment Configuration file
#
# This file can be used as a starting point for your own
# custom .env files, and contains most of the possible settings
# available in a default install.
#
# By default, all of the settings are commented out. If you want
# to override the setting, you must un-comment it by removing the '#'
# at the beginning of the line.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production
; CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'

# app.arduino.token = ''

# app.weatherapi.key  = ''
# app.openweather.key = ''
# app.visualcrossing.key = ''

app.lat = 00.0000
app.lon = 00.0000

# app.narodmon.mac = ''
app.narodmon.lat = 00.0000
app.narodmon.lon = 00.0000
app.narodmon.alt = 0

# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.production.hostname = 127.0.0.1
database.production.port     = 3306
database.production.database = db
# database.production.username = ''
# database.production.password = ''
database.production.DBDriver = MySQLi

database.development.hostname = 127.0.0.1
database.development.port     = 3306
database.development.database = db
# database.development.username = ''
# database.development.password = ''
database.development.DBDriver = MySQLi

